# Copie este arquivo para .env e preencha com seus dados
# NUNCA commite o arquivo .env no GitHub

# --- Credenciais do MEGA ---
# Seu email de login do MEGA
MEGA_EMAIL=

# Sua senha do MEGA
MEGA_PASSWORD=

# --- Configuracao do servidor ---
# Porta onde o servidor vai rodar (padrao: 3000)
PORT=3000

# --- Seguranca ---
# Chave de API para proteger o endpoint /mcp
# Gere uma chave forte, ex: openssl rand -hex 32
# Deixe vazio para desativar autenticacao (nao recomendado em producao)
MCP_API_KEY=
